    {
      "parameters": {
        "jsCode": "const today = new Date();\nconst year = today.getFullYear();\nconst month = today.getMonth(); // current month (0-based)\n\n// salary release = 17th of this month\nconst releaseDate = new Date(year, month, 17);\n\n// if today > 17, push it to next month’s 17\nif (today > releaseDate) {\n  releaseDate.setMonth(month + 1);\n}\n\nreturn [{ releaseDate: releaseDate.toISOString() }];\n"
      },
