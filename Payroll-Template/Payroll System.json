    {
      "parameters": {
        "jsCode": "// Extract the raw date string\nconst rawDate = $json[\"Salary Date\"] || \"\";  \n// Example: \"Date: Wed, 3 Sep 2025 17:17:05 +0500\"\n\n// Extract the day number from the string (3, 15, 31, etc.)\nconst match = rawDate.match(/\\b(\\d{1,2})\\b/);\n\nlet salaryDate = null;\nif (match) {\n  salaryDate = parseInt(match[1], 10);\n}\n\nreturn [{ salaryDate }];\n"
      },
